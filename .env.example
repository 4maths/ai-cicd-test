# GitHub Authentication
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LLM API Keys (chọn ít nhất một)
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LLM Configuration
LLM_PROVIDER=gemini  # hoặc 'groq'
LLM_MODEL=gemini-1.5-flash  # cho Gemini, hoặc 'llama-3-70b-versatile' cho Groq
MAX_TOKENS=1024

# GitHub Configuration
REPO=owner/repository-name
PR_NUMBER=1
RUN_ID=123456789

# Log Analyzer Settings
LOG_TRUNCATE_LENGTH=3000
CONFIDENCE_THRESHOLD=0.7

# Security & Sanitization
SANITIZE_ENABLED=true

# Logging
LOG_LEVEL=INFO
DEBUG_MODE=false
